sub reg_desc {
  my $f = shift;

  open(REG, '< '.$f) or die "$f: $!";
  my @reg = <REG>;
  close REG or die $!;

  @reg == 2 or die;

  my ($type, $params) = $reg[1] =~ /^(\w+)\(([^)]+)\)/ or die;
  my @p = split ',', $params;

  return $type, @p;
}

sub reg_area {
  my $f = shift;

  my ($type, @p) = reg_desc($f);

  for ($type) {
    $_ eq 'circle' and return 2*pi*$p[2]*$p[2];
    $_ eq 'annulus' and return 2*pi*($p[3]*$p[3] - $p[2]*$p[2]);
    die "region type '$type' is unhandled";
  }

}

sub fits_img_sum {
  my ($i, $xcen, $ycen, $r1, $r2) = @_;
  my $coords = fits_img_annulus_ind($i, $xcen, $ycen, $r1, $r2);
  my $tmp = $i->index2d( $coords->slice('(0)'), $coords->slice('(1)') );
  $tmp->badflag(1);
  return $tmp->sum;
}

sub fits_img_annulus_ind {
  my ($i, ,$xcen, $ycen, $r1, $r2) = @_;
  my ($x, $y) = fits_img_xy($i);
  my $dist = sqrt( ($x-$xcen)**2 + ($y-$ycen)**2);
  my $mask = ($dist > $r1) & ($dist < $r2);
  die unless $mask->sum;
  return whichND( $mask );
}

sub fits_img_box_ind {
  my ($i, ,$x1, $x2, $y1, $y2) = @_;
  my ($x, $y) = fits_img_xy($i);
  return whichND( ($x>$x1) & ($x<$x2) & ($y>$y1) & ($y<$y2) );
}

sub fits_img_xy {
  my $i = shift;
  my $x = ($i->xvals+1-$i->hdr->{CRPIX1P})*$i->hdr->{CDELT1P} + $i->hdr->{CRVAL1P};
  my $y = ($i->yvals+1-$i->hdr->{CRPIX2P})*$i->hdr->{CDELT2P} + $i->hdr->{CRVAL2P};
  return $x, $y;
}
