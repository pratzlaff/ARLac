if ($opts{expmap}) {
  _run_command(qw/ punlearn mkexpmap /);
  _run_command('mkexpmap',
	       "asphistfile=$asphist",
	       "xygrid=$xgrid,$ygrid",
	       'useavgaspect=no',
	       'normalize=no',
	       "instmapfile=$instmap",
	       "outfile=$expmap",
	       'clobber=yes',
	      );
}

my $img_clean= "$outdir/img_clean$opts{postfix}.fits";
_run_command(qw/ punlearn dmimgthresh /);
_run_command('dmimgthresh',
	     "infile=$img",
	     "outfile=$img_clean",
	     "expfile=$expmap",
	     'cut=1.5%',
	     'value=0.0',
	     'clobber=yes'
	    );

_run_command('dmimgcalc',
	     "infile=$img_clean",
	     "infile2=$expmap",
	     "outfile=$flux",
	     'op=div',
	     'clobber=yes',
	    );

#  printf "src_r = $src_rad, bg_r = $bg_rad, corr = %f\n\n", $src_rad**2 / ($bg_rad**2 - $src_rad**2);
_run_command('dmstat',
             'infile='.$flux."[sky=region($outdir/src.reg)]",
             'centroid=no',
            );
_run_command('dmstat',
             'infile='.$flux."[sky=region($outdir/bg.reg)]",
             'centroid=no',
            );

exit;

sub mk_regions {
  my ($x, $y, $size_src, $size_bg, $outsrc, $outbg, $outboth) = @_;

  open SRC, '> '.$outsrc or die $!;
  print SRC "# Region file format: CIAO version 1.0\n";
  print SRC "circle($x,$y,$size_src)\n";
  close SRC or die $!;

  open BG, '> '.$outbg or die $!;
  print BG "# Region file format: CIAO version 1.0\n";
  print BG "annulus($x,$y,$size_src,$size_bg)\n";
  close BG or die $!;

  open BOTH, '> '.$outboth or die $!;
  print BOTH "# Region file format: CIAO version 1.0\n";
  print BOTH "circle($x,$y,$size_bg)\n";
  close BOTH or die $!;

  return;
}

sub _run_command {
  my ($cmd, @args) = @_;
  print STDERR join(' ', $cmd, map ( "'$_'", @args)),"\n\n";
  if ($opts{'exec'}) {
    system($cmd, @args);
    die unless ($opts{errignore} or $? == 0);
  }
}

BEGIN {
  my @_ra = (22, 8, 40.8180);
  my @_dec = (45, 44, 32.116);

  sub ra {
    return 15 * ($_ra[0] + $_ra[1]/60 + $_ra[2]/3600);
  }

  sub dec {
    return $_dec[0] + $_dec[1]/60 + $_dec[2]/3600;
  }
};

sub _help {
  exec("$Config{installbin}/perldoc", '-F', $FindBin::Bin . '/' . $FindBin::RealScript);
}

sub _version {
  print $version,"\n";
  exit 0;
}

sub choose_hrci_bg {
  my $hdr = shift;

  my ($year) = $hdr->{'DATE-OBS'} =~/(\d{4})/ or die;

  my @files = glob("$opts{hrcibgdir}/hrciD*statusfilter.fits") or die;

  my @bg_years = map { /hrciD(\d4)/ } @files;

  my @year_diff = map { my ($fyr) = /hrciD(\d{4})/; $year-$fyr; } @files;

  # FIXME - deal with cases like 1999/2000???

  my $file = $files[abs(pdl(\@year_diff))->qsorti->minimum_ind];
  return $files[pdl(\@year_diff)->qsorti->min];
}

sub radii {

  my $f = shift;

  my $hdr = Astro::FITS::CFITSIO::fits_read_header($f.'[srclist]') or die $f;

  my $ra_src = ARLac::ra();
  my $dec_src = ARLac::dec();

  my $ra_pnt = $hdr->{RA_PNT};
  my $dec_pnt = $hdr->{DEC_PNT};

  # FIXME change cos->cos^2 before the next full re-run?
  my $off = sqrt( ($dec_pnt-$dec_src)**2 + ( cos(pi/180*$dec_src) * ($ra_pnt-$ra_src) )**2 );

  $off *= 60;

  # these parameters taken from output of src_sizes.pl
  my $src_r = int(33 * $off + 100);
  my $bg_r = int(1.7 * $src_r);

  # whatever
  $_ += $_%2 for $src_r, $bg_r;

  return $src_r, $bg_r;

}

{
  my $pdir;

  sub pdir_temp {

    return $pdir if $pdir;

    my $key;
    for my $k (qw/ PDIR PFILES UPARM /) {
      exists $ENV{$k} and $key=$k, last;
    }

    my (undef, $sys) = split ';', $ENV{$key}, 2;
    $sys or die "$key=$ENV{$key}"; 

    $pdir = File::Temp->newdir();
    $ENV{$key} = $pdir . ';' . $sys;

    return $pdir;
  }

}
