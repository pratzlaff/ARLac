use Getopt::Long;
my %default_opts = (
		    errignore => 0,
		    exec => 1,
		    skip => 0,
		    toff => 0,
		    tdur => 0,
		    large => 1,
		    hrcibgdir => '/data/legs/rpete/data/ARLac/hrci_bkgrnd',
		    monoenergy => 0.5,
#		    spectrumfile => '/data/legs/rpete/flight/ARLac/old/model_spec2.instmap',
		    spectrumfile => '/data/legs/rpete/flight/ARLac/spectrum/spectrum_erg.txt',
		    id => 'erg',
		    instmap => 1,  # whether to create instrument map
		    expmap => 1,   # whether to create exposure map
		    asphist => 1,  # whether to run asphist
		    );
my %opts = %default_opts;
GetOptions(\%opts,
	   'help!', 'version!', 'debug!',
           'exec!', 'errignore!',
	   'toff=f', 'tdur=f',
	   'outdir=s', 'postfix=s',
	   'spectrumfile=s', 'id=s',
	   'monoenergy=f',
	   'forcecell!',
	   'large!', 'skip!',
	   'instmap!', 'expmap!', 'asphist!',
	   ) or die "Try --help for more information.\n";

if ($opts{debug}) {
  $SIG{__WARN__} = \&Carp::cluck;
  $SIG{__DIE__} = \&Carp::confess;
}
$opts{help} and _help();
$opts{version} and _version();


@ARGV == 1 or die "Usage: $0 [options] dir\n\tTry --help for more information\n";
my $indir = shift;

$opts{postfix} = '' unless exists $opts{postfix};

use PDL;
use PDL::Graphics::PGPLOT;
use Chandra::Tools::Common qw/ read_bintbl_cols /;
use Astro::FITS::CFITSIO;
use Math::Trig qw/ pi /;
use File::Path qw/ mkpath /;
use File::Temp;

use FindBin qw/ $RealBin /;
use lib $RealBin;
use ARLac;

my $repro_dir = 'tg_reprocess';
my $outdir = exists $opts{outdir} ? $opts{outdir} : "$indir/lc";

# final output file
my $flux = "$outdir/flux_$opts{id}_$opts{postfix}.fits";

if ($opts{skip} and -s $flux) {
  warn("$outdir - skipping since $flux exists\n");
  exit;
}

#my $pdir = pdir_temp();
#warn "$outdir - using parameter directory $pdir\n";

mkpath($outdir);

my $evtglob = "$indir/$repro_dir/*evt2_dtffilt.fits*";
my $evt = glob($evtglob);
$evt or die "could not glob $evtglob";

my $dtfglob = "$indir/*/*dtf1*";
my $dtf = glob($dtfglob);
$dtf or die "could not glob $dtfglob";

my $maskglob = "$indir/*/*msk1*";
my $mask = glob($maskglob);
$mask or die "could not glob $maskglob";

my $bpixglob = "$indir/*/*bpix1*";
my $bpix = glob($bpixglob);
$bpix or die "could not glob $bpixglob";

my $pcadglob = "$indir/*/pcad*";
my $pcad = join(',', glob($pcadglob));
$pcad  or die "could not glob $pcadglob";

$evt and $dtf and $mask and $bpix and $pcad or die;

my $hdr = Astro::FITS::CFITSIO::fits_read_header($evt.'[events]');

my $detnam = $hdr->{DETNAM};
($detnam) = $detnam =~ /^'(\S+)/ or die;
#print "detnam=$detnam\n";
$detnam eq 'HRC-I' or $detnam eq 'HRC-S' or die $detnam;

my $cellfile = "$indir/cell_output.fits";

if (! -f $cellfile or $opts{forcecell}) {

  _run_command(qw/ punlearn celldetect /);
  _run_command("celldetect",
	       "infile=$evt",
	       "outfile=$cellfile",
	       "fixedcell=6",
	       'maxlogicalwindow=2048',
	       "clobber=yes",
	      );
}

if ($opts{tdur}) {

  my ($gti_start, $gti_stop) = read_bintbl_cols($evt, qw/ start stop /, { extname => 'gti' }) or die;

  if ($gti_start->at(0) < $hdr->{TSTART}) {
     die("gti start= ".$gti_start->at(0) . ' < TSTART=' . $hdr->{TSTART} );
  }
  if ($gti_stop->at(-1) > $hdr->{TSTOP}) {
     warn("$outdir - gti stop= ".$gti_stop->at(-1) . ' > TSTOP=' . $hdr->{TSTOP} . "\n");
  }

  my $start = $gti_start->at(0)+$opts{toff};
  my $stop = $start + $opts{tdur};

  if ($stop > $gti_stop->at(-1) ) {
     warn("$outdir - stop= " . $stop . ' > gti stop=' . $gti_stop->at(-1) . "\n");
  }

  _run_command(qw/ punlearn dmcopy /);
  _run_command('dmcopy',
               'infile='.$evt."[time=$start:$stop]",
               "outfile=$outdir/evt2_tfilter$opts{postfix}.fits",
               'clobber=yes',
              );

  $evt = "$outdir/evt2_tfilter$opts{postfix}.fits";
  my $dtfstats = "$outdir/dtfstats$opts{postfix}.fits",

  _run_command('punlearn', 'hrc_dtfstats');
  _run_command('hrc_dtfstats',
	       'infile=' . $dtf,
	       'outfile=' . $dtfstats,
	       'gtifile=' . $evt . '[gti]',
	       'clobber=yes',
	      );

  my $hdr = Astro::FITS::CFITSIO::fits_read_header($evt.'[events]');
  my ($dtcor) = read_bintbl_cols($dtfstats, 'dtcor', { extname => 'dtfstats' });
  $dtcor = $dtcor->at(0);

  my $ontime = $hdr->{ONTIME};
  my $livetime = $dtcor * $ontime;

  my %upd = (
	     LIVETIME => sprintf('%12f', $livetime),
	     EXPOSURE => sprintf('%12f', $livetime),
	     DTCOR => sprintf('%12f', $dtcor)
	    );
  while (my ($k, $v) = each %upd) {
    _run_command('punlearn', 'dmhedit');
    _run_command('dmhedit',
		 $evt,
		 'filelist=',
		 'op=add',
		 'key=' . $k,
		 'value=' . $v,
		);
  }

}

my ($src_ra, $src_dec, $src_x, $src_y, $src_detsize, $src_bkgsize) = read_bintbl_cols($cellfile, qw/ ra dec x y detsize bkgsize /, { extname => 'srclist' }) or die;
my $src_dist =sqrt( ( ($src_ra - ra()) * cos(dec() * 2 * pi / 360) )**2 + ($src_dec - dec())**2);
my $src_index = $src_dist->qsorti->at(0);
printf "RA = %.5f, DEC = %.5f\n", ra(), dec();
print "celldetect source index = $src_index\n";

$_ = $_->at($src_index) for $src_ra, $src_dec, $src_x, $src_y, $src_detsize, $src_bkgsize;

$_ = sprintf("%.0f", $_) for $src_x, $src_y;

my ($src_rad, $bg_rad) = radii($cellfile);
my $binning = int($bg_rad/200) + 1;
for ($src_rad, $bg_rad) {
  $_ += $binning - $_ % $binning if $_ % $binning;
}

# my $src_rad = $src_detsize * 4;
# my $bg_rad = $src_rad + 2 * $src_bkgsize;

# if ($bg_rad > 500) {
#   $src_rad = $src_detsize * 2;
#   $bg_rad = $src_rad + $src_bkgsize;
# }

if ( $bg_rad > 500 ) {

  if (!$opts{large}) {
    die "$outdir - bg radius = $bg_rad is too large, use --large to force\n";
  }

  # # rescale the radius to be 1000 pixels maximum
  # if ($bg_rad > 1000) {
  #   my $ratio = 1000/$bg_rad;

  #   my $new_src_rad = int($ratio * $src_rad);
  #   my $new_bg_rad = int($ratio * $bg_rad);

  #   warn "$outdir - rescaling radii: src $src_rad -> $new_src_rad, bg $bg_rad -> $new_bg_rad\n";

  #   $src_rad = $new_src_rad;
  #   $bg_rad = $new_bg_rad;
  # }

}

mk_regions($src_x, $src_y, $src_rad, $bg_rad, "$outdir/src.reg", "$outdir/bg.reg", "$outdir/both.reg");

my $xgrid = sprintf("%.0f:%.0f:$binning", $src_x-$bg_rad, $src_x+$bg_rad);
my $ygrid = sprintf("%.0f:%.0f:$binning", $src_y-$bg_rad, $src_y+$bg_rad);

my ($chipx, $chipy, $chip_id) = read_bintbl_cols($evt, qw/ chipx chipy chip_id /, { extname => 'events', rfilter => sprintf("circle(%g,%g,%g,x,y)", $src_x, $src_y, $bg_rad) }) or die;

my $uniq_chip_id = $chip_id->qsort->uniq;
$uniq_chip_id->nelem == 1 or die;
$chip_id = $chip_id->at(0);

$chip_id = '' if $detnam eq 'HRC-I';

#_run_command(qw/ punlearn ardlib /);
_run_command(qw/ pset ardlib /, 'AXAF_'.$detnam.'_BADPIX_FILE='.$bpix );


my ($chipxmin, $chipxmax) = $chipx->minmax;

my ($chipymin, $chipymax) = $chipy->minmax;

my $chipextra = 200;
$_-= $chipextra for $chipxmin, $chipymin;
$_+= $chipextra for $chipxmax, $chipymax;

my $instgridx="$chipxmin:$chipxmax:1";
my $instgridy="$chipymin:$chipymax:1";

if (0) {

_run_command(qw/ punlearn fluximage /);
_run_command('fluximage',
             'infile='.$evt."[sky=region($outdir/both.reg),pi=[0:300]",
             'outroot=flux'.$opts{postfix},
             'binsize=1',
             'bands=::1.1',
             'asolfile='.$pcad,
             'badpix='.$bpix,
             'maskfile='.$mask,
             'dtffile='.$dtf,
             'cleanup=no',
             'clobber=yes',
             'verbose=3',
             );
exit;

}

my $img = "$outdir/img$opts{postfix}.fits";
_run_command(qw/ punlearn dmcopy /);
_run_command('dmcopy',
             'infile='.$evt."[pi=0:300][bin x=$xgrid,y=$ygrid][opt type=i4,mem=500]",
             "outfile=$img",
             'clobber=yes',
            );

if (0 and $detnam eq 'HRC-I') {

  my $ra_pnt = $hdr->{RA_PNT};
  my $dec_pnt = $hdr->{DEC_PNT};
  my $roll_pnt = $hdr->{ROLL_PNT};

  $_+=0 for $ra_pnt, $dec_pnt, $roll_pnt;

  my $bgevt = choose_hrci_bg($hdr);

  _run_command(qw/ punlearn dmcopy /);
  _run_command('dmcopy',
               'infile='.$bgevt."[chipx=$chipxmin:$chipxmax,chipy=$chipymin:$chipymax]",
               "outfile=$outdir/hrci_bg$opts{postfix}.fits",
               'clobber=y'
              );
  $bgevt = "$outdir/hrci_bg$opts{postfix}.fits";

  _run_command(qw/ punlearn dmhedit /);
  _run_command('dmhedit', $bgevt, 'filelist=none', 'operation=add', 'key=RA_PNT', 'value='.$ra_pnt, 'datatype=indef');
  _run_command('dmhedit', $bgevt, 'filelist=none', 'operation=add', 'key=DEC_PNT', 'value='.$dec_pnt, 'datatype=indef');
  _run_command('dmhedit', $bgevt, 'filelist=none', 'operation=add', 'key=ROLL_PNT', 'value='.$roll_pnt, 'datatype=indef');


  _run_command(qw/ punlearn reproject_events /);
  _run_command('reproject_events',
               'infile='.$bgevt,
               "outfile=$outdir/hrci_bg_filt_reproj$opts{postfix}.fits",
               'aspect='.$pcad,
               'match='.$evt,
               'random=0',
               'clobber=yes',
              );
  $bgevt = "$outdir/hrci_bg_filt_reproj$opts{postfix}.fits";

  my $hrci_bg_img = "$outdir/hrci_bg_img$opts{postfix}.fits";
  _run_command(qw/ punlearn dmcopy /);
  _run_command('dmcopy',
               'infile='.$bgevt."[bin x=$xgrid,y=$ygrid][opt type=i4,mem=500]",
               "outfile=$hrci_bg_img",
               'clobber=yes',
              );

  _run_command('dmimgcalc',
               "infile=$img,$hrci_bg_img",
               'infile2=none',
               "outfile=$outdir/tmp.fits",
               'op=imgout=img1-((img1_exposure/img2_exposure)*img2)',
               'clobber=yes'
              );
  _run_command('mv', "$outdir/tmp.fits", $img);
}

my $asphist = "$outdir/asphist$opts{postfix}.fits";
if ($opts{asphist}) {
  _run_command(qw/ punlearn asphist /);
  _run_command('asphist',
	       'infile='.$pcad,
	       "outfile=$asphist",
